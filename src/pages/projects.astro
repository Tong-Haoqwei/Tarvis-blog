---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';
---

<BaseLayout title="项目 - Tarvis Blog">
  <main class="mx-auto max-w-4xl px-4 py-10 sm:px-6 sm:py-16">
    <header class="mb-10">
      <h1 class="text-xl font-semibold tracking-tight text-gray-900 dark:text-gray-200 sm:text-2xl">
        Projects
      </h1>
    </header>

    <section class="grid gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
      {projects.map((project) => (
        <ProjectCard
          name={project.name}
          description={project.description}
          techStack={project.techStack}
          github={project.github}
          icon={project.icon}
        />
      ))}
    </section>
  </main>
</BaseLayout>

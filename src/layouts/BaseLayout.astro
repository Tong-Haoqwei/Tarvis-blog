---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="技术博客 - 分享编程与技术思考" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100 antialiased">
    <Navbar />
    <slot />
    <footer class="border-t border-gray-200 bg-white dark:border-gray-800/50 dark:bg-gray-950">
      <div class="mx-auto max-w-4xl px-4 py-6 text-center text-xs text-gray-400 dark:text-gray-500 sm:px-6">
        &copy; {new Date().getFullYear()} Tarvis Blog. All rights reserved.
      </div>
    </footer>
  </body>
</html>

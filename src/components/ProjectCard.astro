const svgIcon = iconMap[icon] || iconMap.code;
---

<article class="group rounded-xl border border-gray-200 bg-white p-5 transition-all hover:border-indigo-300 hover:shadow-sm dark:border-gray-800/50 dark:bg-gray-900/50 dark:hover:border-indigo-500/50 sm:p-6">
  <div class="mb-4 flex items-start justify-between">
    <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" set:html={svgIcon} />
    </div>
    <a
      href={github}
      target="_blank"
      rel="noopener noreferrer"
      class="text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition-colors"
      aria-label={`查看 ${name} 源码`}
    >
      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>

  <h3 class="text-base font-semibold text-gray-900 group-hover:text-indigo-600 dark:text-gray-200 dark:group-hover:text-indigo-300 transition-colors">
    {name}
  </h3>
  <p class="mt-2 text-sm leading-relaxed text-gray-500 dark:text-gray-400 flex-1">
    {description}
  </p>

  <div class="mt-4 flex flex-wrap gap-1.5">
    {techStack.map((tech) => (
      <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-700 dark:bg-gray-800 dark:text-gray-400">
        {tech}
      </span>
    ))}
  </div>
</article>
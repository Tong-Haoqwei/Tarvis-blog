<button id="theme-toggle" type="button" aria-label="切换主题" class="theme-toggle">
  <div class="sky-stage">
    <div class="stars"></div>
    <div class="sun"></div>
    <div class="moon"></div>
    <div class="horizon"></div>
  </div>
</button>

<style is:global>
  .theme-toggle {
    position: relative;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: transparent;
    padding: 0;
    overflow: hidden;
    view-transition-name: theme-toggle-btn;
  }

  .theme-toggle:hover {
    transform: scale(1.05);
  }

  .sky-stage {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(180deg, #87CEEB 0%, #B8D4E3 60%, #E8D5B7 100%);
    transition: background 0.7s ease;
  }

  html.dark .sky-stage {
    background: linear-gradient(180deg, #0D1421 0%, #1A237E 60%, #283593 100%);
  }

  .horizon {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 40%;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);
    z-index: 3;
  }

  .stars {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.7s ease;
    z-index: 1;
  }

  html.dark .stars {
    opacity: 1;
  }

  .stars::before {
    content: "";
    position: absolute;
    width: 1.5px;
    height: 1.5px;
    background: white;
    border-radius: 50%;
    box-shadow:
      8px 6px 0 0 white,
      18px 4px 0 0 rgba(255,255,240,0.9),
      28px 10px 0 0 white,
      38px 5px 0 0 #fffde7,
      12px 14px 0 0 white,
      32px 12px 0 0 #f0f0d0,
      22px 18px 0 0 white;
    opacity: 0.8;
  }

  .sun, .moon {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    transition: top 0.7s cubic-bezier(0.34, 1.2, 0.64, 1), opacity 0.7s ease;
    z-index: 2;
  }

  .sun {
    width: 24px;
    height: 24px;
    background: radial-gradient(circle at 30% 30%, #fff7b0, #ffb347);
    border-radius: 50%;
    box-shadow: 0 0 12px #ffdd88, 0 0 24px #ffb347;
    top: 10px;
    opacity: 1;
  }

  html.dark .sun {
    top: 60px;
    opacity: 0;
  }

  .moon {
    width: 21px;
    height: 21px;
    background: radial-gradient(circle at 35% 35%, #f5f5fa, #c0c5d0);
    border-radius: 50%;
    box-shadow: 0 0 10px #b0c2d9, 0 0 20px #aab9d4;
    top: 60px;
    opacity: 0;
  }

  html.dark .moon {
    top: 10px;
    opacity: 1;
  }

  .moon::after {
    content: "";
    position: absolute;
    width: 4.5px;
    height: 4.5px;
    background: #a1a9b5;
    border-radius: 50%;
    top: 5px;
    left: 10px;
    opacity: 0.5;
    box-shadow: 3px 6px 0 1px #9da5b2, 7px 2px 0 0 #b0b8c5, 1px 9px 0 0 #8f98a6;
  }

  @media (prefers-reduced-motion: reduce) {
    .sun, .moon, .stars {
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script is:inline>
(function() {
  var toggle = document.getElementById('theme-toggle');

  function switchTheme(newTheme) {
    if (newTheme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    document.documentElement.style.colorScheme = newTheme;
    localStorage.setItem('theme', newTheme);
  }

  toggle.addEventListener('click', function() {
    var isDark = document.documentElement.classList.contains('dark');
    var newTheme = isDark ? 'light' : 'dark';

    if (document.startViewTransition) {
      document.startViewTransition(function() {
        switchTheme(newTheme);
      });
    } else {
      switchTheme(newTheme);
    }
  });
})();
</script>

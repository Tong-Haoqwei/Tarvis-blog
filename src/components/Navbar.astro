---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/picks', label: '精选集' },
  { href: '/projects', label: '项目' },
  { href: '/about', label: '关于' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="sticky top-0 z-50 border-b border-stone-200/80 bg-stone-50/80 backdrop-blur-md dark:border-gray-800/50 dark:bg-gray-950/80">
  <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/" class="text-lg font-semibold tracking-tight">
      <span class="logo-shimmer">Tarvis</span>
      <span class="text-gray-400 dark:text-gray-500"> Blog</span>
    </a>
    <div class="flex items-center gap-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm transition-colors',
            isActive(link.href)
              ? 'font-medium text-indigo-600 dark:text-indigo-400'
              : 'text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-200',
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="ml-2 rounded-full p-1 text-gray-500 transition-colors hover:bg-stone-200/60 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200">
        <ThemeToggle />
      </div>
    </div>
  </div>
</nav>

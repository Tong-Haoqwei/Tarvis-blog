---
interface Props {
  title: string;
  date: Date;
  tags: string[];
  excerpt?: string;
  slug: string;
}

const { title, date, tags, excerpt, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isoDate = date.toISOString().split('T')[0];
---

<article class="group relative pl-6 py-5 border-l-2 border-stone-200 hover:border-indigo-400 dark:border-gray-800 dark:hover:border-indigo-400 transition-colors">
  <a href={`/posts/${slug}`} class="block">
    <div class="flex items-baseline gap-3">
      <h2 class="text-base font-medium text-gray-900 group-hover:text-indigo-600 dark:text-gray-200 dark:group-hover:text-indigo-300 transition-colors sm:text-lg">
        {title}
      </h2>
      <time datetime={isoDate} class="shrink-0 text-xs text-gray-400 dark:text-gray-500 tabular-nums">
        {formattedDate}
      </time>
    </div>
    {excerpt && (
      <p class="mt-1.5 text-sm leading-relaxed text-gray-500 dark:text-gray-400 line-clamp-2">
        {excerpt}
      </p>
    )}
    {tags.length > 0 && (
      <div class="mt-2.5 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="text-xs text-gray-400 dark:text-gray-500 transition-colors">
            #{tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
